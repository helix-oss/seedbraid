{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": ".claude/hooks/session-start.sh" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-bash-safety.sh" }]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-write-security-check.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-edit-lint.sh" },
          { "type": "command", "command": ".claude/hooks/post-edit-syntax-check.sh" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-compact-save.sh" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": ".claude/hooks/session-stop-log.sh" }]
      }
    ]
  }
}
